{
  "compilerOptions": {
    "target": "ESNext",
    "module": "esnext",
    "strict": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": ["node"],
    //    "jsx": "react-jsx",
    //    "jsxImportSource": "hono/jsx",
    "rootDir": "./src",
    "outDir": "./dist",

    //
    "esModuleInterop": true,
    "moduleResolution": "bundler"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
